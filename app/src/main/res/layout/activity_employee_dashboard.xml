<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    tools:context=".dashboard">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 🟦 TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back"
                android:contentDescription="Back"
                app:tint="#FFFFFF"
                tools:ignore="HardcodedText" />

            <!-- Logo and Employee Name -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal"
                tools:ignore="UseCompoundDrawables">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/logo"
                    android:contentDescription="App Logo"
                    android:layout_marginEnd="8dp"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/txtAppName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Worksafe"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_more_vert"
                android:contentDescription="More options"
                app:tint="#FFFFFF"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <!-- 🧠 MAIN CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="#EAF0F2"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- TITLE -->
                <TextView
                    android:id="@+id/txtEmployeeName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="EMPLOYEE STATUS"
                    android:textColor="#1F2A37"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/txtEmployeeRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Role"
                    android:textColor="#666666"
                    android:textSize="14sp"
                    tools:ignore="HardcodedText" />

                <!-- ❤️🧍 STATS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- ❤️ HEART -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_margin="6dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#2B2B2B"
                        app:cardCornerRadius="16dp"
                        tools:ignore="TextSizeCheck">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Heart Rate"
                                android:textColor="#BDBDBD"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="❤️"
                                android:textSize="24sp"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:id="@+id/txtHeartRate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="72 BPM"
                                android:textColor="#4CAF50"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:id="@+id/txtHeartStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="STABLE"
                                android:textColor="#4CAF50"
                                tools:ignore="HardcodedText" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- 🧍 MOTION -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_margin="6dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#2B2B2B"
                        app:cardCornerRadius="16dp"
                        tools:ignore="TextSizeCheck">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Motion &amp; Status"
                                android:textColor="#BDBDBD"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🚶"
                                android:textSize="24sp"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:id="@+id/txtMotion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ACTIVE"
                                android:textColor="#4FC3F7"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />


                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- 🗺️ MAP -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="20dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#1C1C1C">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="Map background"
                            android:scaleType="centerCrop"
                            android:src="@drawable/background"
                            tools:ignore="HardcodedText" />

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_gravity="center"
                            android:contentDescription="Location pin"
                            android:src="@android:drawable/ic_menu_mylocation"
                            app:tint="#FF0000"
                            tools:ignore="HardcodedText,ImageContrastCheck" />
                    </FrameLayout>
                </androidx.cardview.widget.CardView>

                <!-- 🟢 STATUS -->
                <TextView
                    android:id="@+id/txtGlobalStatus"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:background="#4CAF50"
                    android:gravity="center"
                    android:text="SAFE"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText,TextContrastCheck" />

                <!-- 🌡️ ENVIRONMENT -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="ENVIRONMENTAL CONDITIONS"
                    android:textColor="#1F2A37"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- 🌡️ TEMP -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_margin="6dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#2B2B2B"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Temperature"
                                android:textColor="#FFFFFF"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:id="@+id/txtTemp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="36.8°C"
                                android:textColor="#4FC3F7"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:id="@+id/txtTempStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="NORMAL"
                                android:textColor="#4CAF50"
                                tools:ignore="HardcodedText" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- ☣️ GAS -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_margin="6dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#2B2B2B"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Gas Level"
                                android:textColor="#FFFFFF"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:id="@+id/txtGas"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="450 PPM"
                                android:textColor="#FFB74D"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:id="@+id/txtGasStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CAUTION"
                                android:textColor="#FFB74D"
                                tools:ignore="HardcodedText" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
